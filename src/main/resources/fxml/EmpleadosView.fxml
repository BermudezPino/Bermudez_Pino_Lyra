<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.lyra.controller.EmpleadosController"
      spacing="10">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Empleados" styleClass="section-title"/>
        <Button text="Nuevo Empleado" onAction="#nuevoEmpleado" styleClass="btn-primary"/>
    </HBox>

    <TableView fx:id="tablaEmpleados" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"        text="ID"       prefWidth="50"/>
            <TableColumn fx:id="colNombre"    text="Nombre"   prefWidth="120"/>
            <TableColumn fx:id="colApellidos" text="Apellidos" prefWidth="140"/>
            <TableColumn fx:id="colCargo"     text="Cargo"    prefWidth="130"/>
            <TableColumn fx:id="colActivo"    text="Activo"   prefWidth="70"/>
        </columns>
    </TableView>

    <TitledPane text="Datos del empleado" expanded="true">
        <GridPane hgap="10" vgap="8">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <Label text="Nombre:"       GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="tfNombre"       GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200"/>
            <Label text="Apellidos:"    GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="tfApellidos"    GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            <Label text="DNI:"          GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="tfDni"          GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            <Label text="Email:"        GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="tfEmail"        GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            <Label text="Teléfono:"     GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <TextField fx:id="tfTelefono"     GridPane.rowIndex="4" GridPane.columnIndex="1"/>
            <Label text="Cargo:"        GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <TextField fx:id="tfCargo"        GridPane.rowIndex="5" GridPane.columnIndex="1"/>
            <Label text="Contratación:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
            <DatePicker fx:id="dpFechaContratacion" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
            <Label text="Activo:"       GridPane.rowIndex="7" GridPane.columnIndex="0"/>
            <CheckBox fx:id="cbActivo"        GridPane.rowIndex="7" GridPane.columnIndex="1"/>
            <HBox spacing="10" GridPane.rowIndex="8" GridPane.columnIndex="1">
                <Button text="Guardar"  onAction="#guardarEmpleado"  styleClass="btn-primary"/>
                <Button text="Eliminar" onAction="#eliminarEmpleado" styleClass="btn-danger"/>
                <Button text="Limpiar"  onAction="#limpiarFormulario"/>
            </HBox>
        </GridPane>
    </TitledPane>

</VBox>
