<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.lyra.controller.ServiciosController"
      spacing="10">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Servicios Extra" styleClass="section-title"/>
        <Button text="Nuevo Servicio" onAction="#nuevoServicio" styleClass="btn-primary"/>
    </HBox>

    <TableView fx:id="tablaServicios" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"         text="ID"          prefWidth="50"/>
            <TableColumn fx:id="colNombre"     text="Nombre"      prefWidth="180"/>
            <TableColumn fx:id="colPrecio"     text="Precio €"    prefWidth="90"/>
            <TableColumn fx:id="colDisponible" text="Disponible"  prefWidth="90"/>
        </columns>
    </TableView>

    <TitledPane text="Datos del servicio" expanded="true">
        <GridPane hgap="10" vgap="8">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <Label text="Nombre:"      GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="tfNombre"      GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200"/>
            <Label text="Descripción:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextArea fx:id="taDescripcion"  GridPane.rowIndex="1" GridPane.columnIndex="1" prefHeight="60"/>
            <Label text="Precio €:"    GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="tfPrecio"      GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            <Label text="Disponible:"  GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <CheckBox fx:id="cbDisponible"   GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            <HBox spacing="10" GridPane.rowIndex="4" GridPane.columnIndex="1">
                <Button text="Guardar"  onAction="#guardarServicio"  styleClass="btn-primary"/>
                <Button text="Eliminar" onAction="#eliminarServicio" styleClass="btn-danger"/>
                <Button text="Limpiar"  onAction="#limpiarFormulario"/>
            </HBox>
        </GridPane>
    </TitledPane>

</VBox>
